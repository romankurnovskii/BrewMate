{
  "name": "brewmate",
  "version": "1.0.25",
  "description": "BrewMate - A modern package manager GUI for macOS",
  "author": "Roman Kurnovskii",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:renderer && npm run copy:static",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "copy:static": "mkdir -p dist/renderer && mkdir -p dist/assets && mkdir -p dist/locales && cp src/renderer/index.html dist/renderer/ && cp src/renderer/styles.css dist/renderer/ && cp locales/*.json dist/locales/ && if [ -d src/assets ]; then cp -r src/assets/* dist/assets/; elif [ -d assets ]; then cp -r assets/* dist/assets/; fi",
    "start": "electron .",
    "start:dev": "NODE_ENV=development npm start",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:universal": "./scripts/build-direct-universal.sh",
    "build:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "build:mac:x64": "npm run build && electron-builder --mac --x64",
    "build:mas": "./scripts/build-mas-universal.sh",
    "pre-submit": "echo 'Pre-submit check not implemented yet'",
    "dist": "npm run build && electron-builder --mac",
    "dist:mac": "npm run build && electron-builder --mac",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "dotenv": "^17.2.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "jest": "^30.3.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "i18next": "^26.3.1",
    "react-i18next": "^17.0.8"
  }
}
