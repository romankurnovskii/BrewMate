# ═══════════════════════════════════════════════════════════════
#             BREWMATE DEVELOPER ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════
# Copy this file to '.env' and fill in your custom credentials.
# WARNING: Never commit your actual '.env' file to version control!
# ═══════════════════════════════════════════════════════════════

# ---------------------------------------------------------------
# 🍎 1. COMMON APPLE DEVELOPER CREDENTIALS
# ---------------------------------------------------------------
# Your Apple ID email address
APPLE_ID=your-apple-id@email.com

# An App-Specific Password generated on your Apple ID portal.
# Required for notarizing direct builds and uploading MAS builds.
# Generate here: https://appleid.apple.com/account/manage
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Apple Developer Team ID (10-character alphanumeric string)
# Found in your Apple Developer Console: https://developer.apple.com/account/
APPLE_TEAM_ID=ZJBVSAC8G7


# ---------------------------------------------------------------
# 🌐 2. DIRECT DISTRIBUTION CONFIGURATION (DMG / WEBSITE)
# ---------------------------------------------------------------
# Certificates required: "Developer ID Application" and "Developer ID Installer"
# List local certificates: security find-identity -v -p codesigning
# Ensure the certificates are installed in your macOS Keychain.

# Full identity name or thumbprint for signing the App binary
APPLE_SIGNING_IDENTITY='Developer ID Application: Your Name (ZJBVSAC8G7)'

# Full identity name or thumbprint for signing the installer package/DMG
APPLE_INSTALLER_IDENTITY='Developer ID Installer: Your Name (ZJBVSAC8G7)'


# ---------------------------------------------------------------
# 🏪 3. MAC APP STORE (MAS) / TESTFLIGHT CONFIGURATION
# ---------------------------------------------------------------
# Certificates required: "3rd Party Mac Developer Application" and "3rd Party Mac Developer Installer"
# Provisioning Profile required: Distribution profile for Mac App Store (.provisionprofile)

# Path to your local App Store Distribution Provisioning Profile
# This will be copied dynamically to the build location during the build process.
APPLE_PROVISIONING_PROFILE='.credentials/Your_AppStore_Distribution.provisionprofile'


# ---------------------------------------------------------------
# 📦 4. CI/CD BASE64 CERTIFICATES (OPTIONAL)
# ---------------------------------------------------------------
# Used on CI runners (like GitHub Actions) to dynamically import
# certificates and provisioning profiles into a temporary keychain.
# Create base64: base64 -i your_cert.p12 | pbcopy
MACOS_CERTIFICATE=
MACOS_CERTIFICATE_PWD=
MACOS_PROVISIONING_PROFILE=
