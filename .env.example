# Apple Developer ID Configuration for Direct Distribution
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# Notarization credentials (required for Gatekeeper)
# Get app-specific password from: https://appleid.apple.com/account/manage
APPLE_ID=your-email@example.com
APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password
APPLE_TEAM_ID=YOUR_TEAM_ID

# Code signing identity (Developer ID, NOT Mac App Store)
# Find your identity: security find-identity -p codesigning -v
# Example: "Developer ID Application: Your Name (TEAM_ID)"
APPLE_SIGNING_IDENTITY='Developer ID Application: Your Name (TEAM_ID)'

# Optional: Developer ID Installer certificate for signing the DMG
APPLE_INSTALLER_IDENTITY='Developer ID Installer: Your Name (TEAM_ID)'

MACOS_CERTIFICATE
MACOS_CERTIFICATE_PWD
MACOS_PROVISIONING_PROFILE
